<UserControl x:Class="TrustsAndTpa.TrustAndTpa01.Views.TrustView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:viewModels="clr-namespace:TrustAndTpa.TrustAndTpa03.ViewModels"
             xmlns:viewModels1="clr-namespace:TrustsAndTpa.TrustAndTpa03.ViewModels"
             xmlns:views="clr-namespace:TrustsAndTpa.TrustAndTpa01.Views"
             d:DataContext="{d:DesignInstance Type=viewModels1:TrustViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!--Trust panel-->
    <Grid x:Name="TrustViewRoot" Margin="30,15" Background="White" >
        <Grid DataContext="{Binding StMch}"
              views:BusyCursorBehavior.ShowWaitCursor="{Binding DataContext.IsBusy, ElementName=TrustViewRoot}"
              >
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Content="Trust" FontSize="16"  FontWeight="Bold" HorizontalAlignment="Left" Height="30"/>
            <Grid Grid.Row="1" >
                <Button Content="Add Trust" Width="auto" Height="30" HorizontalAlignment="Left" FontSize="16" 
                        Padding="10,0" Foreground="White" 
                        Visibility="{Binding Path=UnboundVisibility}" 
                        Background="#009adf" 
                        Command="{Binding DataContext.SetEditingStateCommand, ElementName=TrustViewRoot}"
                        />
                <StackPanel Orientation="Vertical" Visibility="{Binding AccountBoxVisibility}">
                    <StackPanel Orientation="Horizontal" >
                        <StackPanel Orientation="Vertical" Visibility="{Binding EditingVisibility}" >
                            <TextBlock Text="Trust Number" Height="23" FontSize="12" 
                                               Margin="0,0,0,-5" 
                                               Visibility="{Binding EditingVisibilityHeader}"
                                               />
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="16" Width="150" Height="26" HorizontalAlignment="Left" />
                                <Button Content="Search" Margin="25,0" Width="60" Height="25" HorizontalAlignment="Left"
                                        IsEnabled="{Binding Path=CanSearch}" Foreground="White" FontSize="16"
                                        Background="#009adf" 
                                        Command="{Binding DataContext.SetSearchingStateCommand, ElementName=TrustViewRoot}" />
                            </StackPanel>
                            <TextBlock Text="Account not found" Foreground="Red" FontSize="12"
                                       HorizontalAlignment="Left" 
                                       Visibility="{Binding AccountNotFoundMessageVisibilty}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                    Visibility="{Binding RemoveAccountVisibility}" >
                            <Label Content="{Binding AccountName}" FontSize="15" 
                                    BorderBrush="LightGray" BorderThickness="2" 
                                    Padding="5,0,5,0"
                                    Height="auto" Width="auto" HorizontalAlignment="Left"/>
                            <TextBlock Text="Remove" Foreground="#009adf" Width="auto" 
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        FontSize="11" FontWeight="Bold" Height="25" 
                                        Margin="10,0,0,0" >
                                <b:Interaction.Triggers>
                                    <b:EventTrigger EventName="MouseLeftButtonDown">
                                        <b:InvokeCommandAction 
                                            Command="{Binding DataContext.RemoveBindingCommand, ElementName=TrustViewRoot}" />
                                    </b:EventTrigger>
                                </b:Interaction.Triggers>
                                <TextBlock.Resources>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Resources>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>

</UserControl>
