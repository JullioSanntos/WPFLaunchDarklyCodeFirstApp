<Window x:Class="TrustsAndTpa.TrustsAndTpa01.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        
        xmlns:viewModels="clr-namespace:TrustsAndTpa.TrustsAndTpa03.ViewModels"
        xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:views="clr-namespace:TrustsAndTpa.TrustsAndTpa01.Views"
        mc:Ignorable="d"
        Title="MainView" Height="600" Width="800">
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:TrustViewModel}">
            <views:TrustView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TpaViewModel}">
            <views:TpaView />
        </DataTemplate>

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="80*" MinWidth="300"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#4f72A4">

        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Matrix & Bin panel-->
            <Border Grid.Row="0"  BorderThickness="2" BorderBrush="Gray" Margin="50,20" >
                <TextBlock Text="Matrix &amp; Bin panel Completed" FontSize="20"  FontWeight="Bold" 
                           Opacity="0.3"
                           HorizontalAlignment="Center" Height="30"/>
            </Border>

            <!--Trust panel-->
            <Border Grid.Row="1" BorderThickness="2" BorderBrush="Gray" Margin="50,20">
                <ContentControl Content="{Binding CurrentTrustViewModel}" />
            </Border>

            <!--TPA panel-->
            <Border Grid.Row="2" BorderThickness="2" BorderBrush="Gray" Margin="50,20">
                <ContentControl Content="{Binding CurrentTpaViewModel}" />
            </Border>

        </Grid>
    </Grid>

</Window>
